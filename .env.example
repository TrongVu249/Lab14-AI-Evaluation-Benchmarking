# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Fallback to standard OpenAI API Configuration
# OPENAI_API_KEY=your_openai_api_key_here

# Models Selection for Evaluation
# Example OpenRouter Models:
# - openai/gpt-4o-mini
# - openai/gpt-4o
# - anthropic/claude-3.5-sonnet
# - meta-llama/llama-3-8b-instruct
EVAL_MODEL_NAME=openai/gpt-4o-mini
JUDGE_MODEL_A=openai/gpt-4o-mini
JUDGE_MODEL_B=meta-llama/llama-3-8b-instruct
TIE_BREAKER_MODEL=openai/gpt-4o
